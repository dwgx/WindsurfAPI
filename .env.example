# ========== Server ==========
# Bind host (secure default: localhost only)
HOST=127.0.0.1
PORT=3003
# API key for incoming requests (leave empty for open access)
API_KEY=
# Directory for persisted JSON state and logs (Docker 推荐用 /data)
DATA_DIR=

# ========== Codeium Auth ==========
# Option 1: Direct API key from Windsurf
CODEIUM_API_KEY=

# Option 2: Token from windsurf.com/show-auth-token
CODEIUM_AUTH_TOKEN=

# ========== Language Server ==========
# Path to language server binary. Leave empty to use the platform default:
# Linux: /opt/windsurf/language_server_linux_x64
# macOS: ~/.windsurf/language_server_macos_{arm|x64}
LS_BINARY_PATH=
# LS data directory root (leave empty to use platform default)
LS_DATA_DIR=
# Workspace directory used by the proxy (auto-cleaned on startup)
WORKSPACE_DIR=
# gRPC port for language server
LS_PORT=42100

# ========== Dashboard ==========
# Dashboard password — protects /dashboard and all /dashboard/api/* endpoints.
# If empty AND API_KEY is also empty, dashboard is completely open (anyone can
# view accounts, API keys, logs, and trigger updates). Set this for any
# internet-facing deployment.
DASHBOARD_PASSWORD=

# ========== Advanced ==========
CODEIUM_API_URL=https://server.self-serve.windsurf.com
DEFAULT_MODEL=claude-4.5-sonnet-thinking
MAX_TOKENS=8192
LOG_LEVEL=info
# Optional prompt sample logging (default off, metadata-only logging stays on)
LOG_PROMPT_SAMPLES=0
# Forward caller environment hints (default off)
FORWARD_CALLER_ENV=0
# Optional allowlist when FORWARD_CALLER_ENV=1: cwd,git,platform,os
FORWARD_CALLER_ENV_FIELDS=
# Allow full API key reveal endpoint in dashboard (default off)
ENABLE_REVEAL_API_KEY=0
# High-risk dashboard actions (default secure/off unless noted)
ENABLE_SELF_UPDATE=0
ENABLE_BATCH_LOGIN=0
ENABLE_TOKEN_REFRESH=1
ENABLE_LS_RESTART=0
